# Jekyll build output & caches
_site/
.sass-cache/
.jekyll-cache/
.jekyll-metadata

# Ruby / Bundler
Gemfile.lock
vendor/
.bundle/

# Local-only dev shims (e.g. tainted? compat for running old gems on Ruby 4)
.local/

# Node / serverless API deps & secrets
node_modules/
.env
.env.*
!.env.example
.vercel/
.netlify/

# Audio: only the trimmed preview clips ship. Full-song masters dropped into
# assets/audio/ (any other name) stay local and are never published.
assets/audio/*.mp3
!assets/audio/pink-noise.mp3
!assets/audio/catseye.mp3
!assets/audio/neverless.mp3
!assets/audio/exotic.mp3
!assets/audio/flashing-lights.mp3
!assets/audio/neverless-cinematic.mp3
!assets/audio/exodia.mp3
!assets/audio/stay.mp3
!assets/audio/worlds-away.mp3

# OS / editor cruft
.DS_Store
Thumbs.db
*~
