# =============================================================================
# Environment variables for the serverless API functions (api/*.js).
# Copy this file to ".env" for local dev, and set the same vars in your
# hosting platform's dashboard (Vercel: Project → Settings → Environment
# Variables; Netlify: Site settings → Environment variables).
#
# These are read SERVER-SIDE only. They never ship to the browser.
# =============================================================================

# TODO(Kevin): add your YouTube Data API v3 key.
# Create one at https://console.cloud.google.com/ → enable "YouTube Data API
# v3" → Credentials → API key. Used by api/latest-highlight.js to find the
# latest "Bagwork 2.0" highlight on the @RoundballBC channel.
YOUTUBE_API_KEY=

# Optional: your player/team page URL on stats.roundball.ca. You can set it
# here OR directly in api/_config.js (ROUNDBALL_PLAYER_URL). Leave blank until
# the season starts — the stats API returns a graceful pre-season state.
# TODO(Kevin): set once the season starts.
ROUNDBALL_PLAYER_URL=
